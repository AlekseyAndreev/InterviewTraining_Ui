{
  "auth": {
    "authority": "https://interviewtrainingauth",
    "clientId": "interview_training_web_spa",
    "scope": "openid profile roles permissions interview_training_signalr_web interview_training_interview offline_access",
    "responseType": "code",
    "silentRenew": true,
    "useRefreshToken": true,
    "autoUserInfo": true,
    "logLevel": 3,
    "secureRoutes": [
      "https://interviewtrainingauth/",
      "http://interviewtrainingapi/"
    ],
    "ignoreNonceAfterRefresh": true,
    "disableIatOffsetValidation": true,
    "maxIdTokenIatOffsetAllowedInSeconds": 600
  },
  "api": {
    "baseUrl": "http://interviewtrainingapi"
  }
}
